{
  "name": "agent-skills-tui-ts",
  "version": "0.1.0",
  "description": "Node.js and TypeScript TUI for browsing and installing Codex skills",
  "type": "module",
  "private": true,
  "bin": {
    "agent-skills-tui": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --dts --clean",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check ."
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fuzzysort": "^3.1.0",
    "gray-matter": "^4.0.3",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/ink-testing-library": "1.0.4",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "ink-testing-library": "4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.12.1+sha512.f0dda8580f0ee9481c5c79a1d927b9164f2c478e90992ad268bbb2465a736984391d6333d2c327913578b2804af33474ca554ba29c04a8b13060a717675ae3ac"
}
